{
  "displayName": "ML Training Platform - Overview",
  "mosaicLayout": {
    "tiles": [
      {
        "width": 12,
        "height": 2,
        "widget": {
          "title": "Quick Links",
          "text": {
            "content": "**[Cluster Director Console](https://console.cloud.google.com/cluster-director?project=tpu-launchpad-playground)** | **[Logs Explorer](https://console.cloud.google.com/logs/query;query=resource.type%3D%22k8s_container%22%0Aresource.labels.cluster_name%3D%22shun-elm-poc-gke%22%0Aresource.labels.container_name%3D%22jax-tpu%22?project=tpu-launchpad-playground)** | **[Submit Job Guide](https://github.com/elbertwang/ml-training-platform/blob/main/docs/submit-job.md)**\n\nLog query template: `labels.\"k8s-pod/jobset_sigs_k8s_io/jobset-name\"=\"<YOUR_JOB_NAME>\"`",
            "format": "MARKDOWN"
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 2,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "TPU Utilization (Duty Cycle)",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "resource.type=\"k8s_node\" AND metric.type=\"kubernetes.io/node/accelerator/duty_cycle\" AND resource.labels.cluster_name=\"shun-elm-poc-gke\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_MEAN",
                      "crossSeriesReducer": "REDUCE_MEAN",
                      "groupByFields": ["resource.labels.node_name"]
                    }
                  }
                },
                "plotType": "LINE"
              }
            ],
            "yAxis": {
              "label": "Duty Cycle (%)"
            }
          }
        }
      },
      {
        "xPos": 6,
        "yPos": 2,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "TPU HBM Memory Used",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "resource.type=\"k8s_node\" AND metric.type=\"kubernetes.io/node/accelerator/memory_used\" AND resource.labels.cluster_name=\"shun-elm-poc-gke\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_MEAN",
                      "crossSeriesReducer": "REDUCE_MEAN",
                      "groupByFields": ["resource.labels.node_name"]
                    }
                  }
                },
                "plotType": "LINE"
              }
            ],
            "yAxis": {
              "label": "Bytes"
            }
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 6,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Pod CPU Usage",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "resource.type=\"k8s_container\" AND metric.type=\"kubernetes.io/container/cpu/core_usage_time\" AND resource.labels.cluster_name=\"shun-elm-poc-gke\" AND resource.labels.container_name=\"jax-tpu\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_RATE",
                      "crossSeriesReducer": "REDUCE_SUM",
                      "groupByFields": ["resource.labels.pod_name"]
                    }
                  }
                },
                "plotType": "LINE"
              }
            ],
            "yAxis": {
              "label": "CPU Cores"
            }
          }
        }
      },
      {
        "xPos": 6,
        "yPos": 6,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Pod Memory Usage",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "resource.type=\"k8s_container\" AND metric.type=\"kubernetes.io/container/memory/used_bytes\" AND resource.labels.cluster_name=\"shun-elm-poc-gke\" AND resource.labels.container_name=\"jax-tpu\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_MEAN",
                      "crossSeriesReducer": "REDUCE_SUM",
                      "groupByFields": ["resource.labels.pod_name"]
                    }
                  }
                },
                "plotType": "LINE"
              }
            ],
            "yAxis": {
              "label": "Bytes"
            }
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 10,
        "width": 12,
        "height": 6,
        "widget": {
          "title": "Training Job Logs (jax-tpu containers)",
          "logsPanel": {
            "filter": "resource.type=\"k8s_container\"\nresource.labels.cluster_name=\"shun-elm-poc-gke\"\nresource.labels.container_name=\"jax-tpu\"",
            "resourceNames": [
              "projects/tpu-launchpad-playground"
            ]
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 16,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Pod Restart Count",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "resource.type=\"k8s_container\" AND metric.type=\"kubernetes.io/container/restart_count\" AND resource.labels.cluster_name=\"shun-elm-poc-gke\" AND resource.labels.container_name=\"jax-tpu\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_MAX",
                      "crossSeriesReducer": "REDUCE_SUM",
                      "groupByFields": ["resource.labels.pod_name"]
                    }
                  }
                },
                "plotType": "LINE"
              }
            ]
          }
        }
      },
      {
        "xPos": 6,
        "yPos": 16,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Node Count by Status",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "resource.type=\"k8s_node\" AND metric.type=\"kubernetes.io/node/status_condition\" AND resource.labels.cluster_name=\"shun-elm-poc-gke\" AND metric.labels.condition=\"Ready\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_MEAN",
                      "crossSeriesReducer": "REDUCE_COUNT_TRUE"
                    }
                  }
                },
                "plotType": "LINE"
              }
            ]
          }
        }
      }
    ]
  }
}
