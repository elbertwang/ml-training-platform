      {
        "xPos": 0,
        "yPos": 16,
        "width": 12,
        "height": 16,
        "widget": {
          "title": "Infra Metrics",
          "collapsibleGroup": {}
        }
      },
      {
        "xPos": 0,
        "yPos": 16,
        "width": 12,
        "height": 2,
        "widget": {
          "title": "",
          "text": {
            "content": "Infrastructure metrics from GKE. Use the **cluster_name** filter above to select a cluster.",
            "format": "MARKDOWN"
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 18,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "TPU Utilization (Duty Cycle)",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "resource.type=\"k8s_node\" AND metric.type=\"kubernetes.io/node/accelerator/duty_cycle\" AND resource.labels.cluster_name=\"${cluster_name}\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_MEAN",
                      "crossSeriesReducer": "REDUCE_MEAN",
                      "groupByFields": ["resource.labels.node_name"]
                    }
                  }
                },
                "plotType": "LINE"
              }
            ],
            "yAxis": {
              "label": "Duty Cycle (%)"
            }
          }
        }
      },
      {
        "xPos": 6,
        "yPos": 18,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "TPU HBM Memory Used",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "resource.type=\"k8s_node\" AND metric.type=\"kubernetes.io/node/accelerator/memory_used\" AND resource.labels.cluster_name=\"${cluster_name}\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_MEAN",
                      "crossSeriesReducer": "REDUCE_MEAN",
                      "groupByFields": ["resource.labels.node_name"]
                    }
                  }
                },
                "plotType": "LINE"
              }
            ],
            "yAxis": {
              "label": "Bytes"
            }
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 22,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Pod CPU Usage",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "resource.type=\"k8s_container\" AND metric.type=\"kubernetes.io/container/cpu/core_usage_time\" AND resource.labels.cluster_name=\"${cluster_name}\" AND resource.labels.container_name=\"jax-tpu\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_RATE",
                      "crossSeriesReducer": "REDUCE_SUM",
                      "groupByFields": ["resource.labels.pod_name"]
                    }
                  }
                },
                "plotType": "LINE"
              }
            ],
            "yAxis": {
              "label": "CPU Cores"
            }
          }
        }
      },
      {
        "xPos": 6,
        "yPos": 22,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Pod Memory Usage",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "resource.type=\"k8s_container\" AND metric.type=\"kubernetes.io/container/memory/used_bytes\" AND resource.labels.cluster_name=\"${cluster_name}\" AND resource.labels.container_name=\"jax-tpu\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_MEAN",
                      "crossSeriesReducer": "REDUCE_SUM",
                      "groupByFields": ["resource.labels.pod_name"]
                    }
                  }
                },
                "plotType": "LINE"
              }
            ],
            "yAxis": {
              "label": "Bytes"
            }
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 26,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Pod Restart Count",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "resource.type=\"k8s_container\" AND metric.type=\"kubernetes.io/container/restart_count\" AND resource.labels.cluster_name=\"${cluster_name}\" AND resource.labels.container_name=\"jax-tpu\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_MAX",
                      "crossSeriesReducer": "REDUCE_SUM",
                      "groupByFields": ["resource.labels.pod_name"]
                    }
                  }
                },
                "plotType": "LINE"
              }
            ]
          }
        }
      },
      {
        "xPos": 6,
        "yPos": 26,
        "width": 6,
        "height": 4,
        "widget": {
          "title": "Node Count (Ready)",
          "xyChart": {
            "dataSets": [
              {
                "timeSeriesQuery": {
                  "timeSeriesFilter": {
                    "filter": "resource.type=\"k8s_node\" AND metric.type=\"kubernetes.io/node/status_condition\" AND resource.labels.cluster_name=\"${cluster_name}\" AND metric.labels.condition=\"Ready\"",
                    "aggregation": {
                      "alignmentPeriod": "60s",
                      "perSeriesAligner": "ALIGN_MEAN",
                      "crossSeriesReducer": "REDUCE_COUNT_TRUE"
                    }
                  }
                },
                "plotType": "LINE"
              }
            ]
          }
        }
      },
      {
        "xPos": 0,
        "yPos": 32,
        "width": 12,
        "height": 6,
        "widget": {
          "title": "Training Job Logs",
          "logsPanel": {
            "filter": "resource.type=\"k8s_container\"\nresource.labels.cluster_name=\"shun-elm-poc-gke\"\nresource.labels.container_name=\"jax-tpu\"",
            "resourceNames": [
              "projects/tpu-launchpad-playground"
            ]
          }
        }
      }
    ]
  }
}
